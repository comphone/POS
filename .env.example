SECRET_KEY='your-strong-secret-key-here'
DATABASE_URL='sqlite:///app.db' # หรือ path อื่นๆ เช่น sqlite:///C:/path/to/your/app.db

# LINE Messaging API Configuration (สำหรับเฟส 3)
# คุณต้องสร้าง Messaging API Channel ใน LINE Developers Console เพื่อรับค่าเหล่านี้
LINE_CHANNEL_ACCESS_TOKEN='your_line_channel_access_token_here'
LINE_CHANNEL_SECRET='your_line_channel_secret_here'
# User ID หรือ Group ID ที่ต้องการส่งข้อความแจ้งเตือนไปหา
# ตัวอย่าง: Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (สำหรับ User ID)
# หรือ Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (สำหรับ Group ID)
LINE_USER_ID_FOR_NOTIFICATIONS='your_line_user_or_group_id_for_notifications_here'
